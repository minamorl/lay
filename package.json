{
  "name": "@minamorl/lay",
  "version": "1.0.0",
  "description": "Lens-based reactive state container with composable observation algebra. Eliminate the mapping layer.",
  "keywords": [
    "lens",
    "optics",
    "state",
    "reactive",
    "proxy",
    "typescript",
    "react",
    "presheaf",
    "category-theory"
  ],
  "homepage": "https://github.com/minamorl/lay",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minamorl/lay.git"
  },
  "bugs": {
    "url": "https://github.com/minamorl/lay/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    }
  },
  "scripts": {
    "build": "pnpm run clean && tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "dev": "vitest",
    "lint": "eslint \"src/**/*.ts\""
  },
  "license": "MIT",
  "packageManager": "pnpm@9.1.1",
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
